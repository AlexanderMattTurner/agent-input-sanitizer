  "split": [{ "id": "html", "file": "src/html.mjs" }],
  "groups": [
    { "id": "output", "mutate": "src/output.mjs" },
    { "id": "rehydrate", "mutate": "src/rehydrate.mjs" },
    { "id": "invisible-index", "mutate": "src/invisible.mjs,src/index.mjs" },
    {
      "id": "instructions-gates",
      "mutate": "src/instructions.mjs,src/gates.mjs"
    },
    { "id": "viewmap-prompt", "mutate": "src/view-map.mjs,src/prompt.mjs" },
    {
      "id": "confusables-layer1",
      "mutate": "src/confusables.mjs,src/layer1.mjs"
    },
    { "id": "joining-type", "mutate": "src/joining-type.mjs" },
    {
      "id": "standardized-variants",
      "mutate": "src/standardized-variants.mjs"
    }
  ]
}
